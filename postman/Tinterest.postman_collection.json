{
  "info": {
    "_postman_id": "15ec0e10-4ff2-4f3b-9b4d-tinterest-api",
    "name": "Tinterest API",
    "description": "Local demo collection for the Tinterest Spring Boot backend. Run requests in order from the Demo Flow folder. After each register request, copy the verification code from backend logs into verificationCode or verificationCode2.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('demoRunId')) {",
          "  pm.environment.set('demoRunId', Date.now().toString());",
          "}",
          "const runId = pm.environment.get('demoRunId');",
          "if (!pm.environment.get('email')) {",
          "  pm.environment.set('email', `demo.user1.${runId}@example.com`);",
          "}",
          "if (!pm.environment.get('email2')) {",
          "  pm.environment.set('email2', `demo.user2.${runId}@example.com`);",
          "}",
          "if (!pm.environment.get('password')) {",
          "  pm.environment.set('password', 'Password123');",
          "}"
        ]
      }
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Demo Flow",
      "item": [
        {
          "name": "01 Register user 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Registration accepted', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 409]);",
                  "});",
                  "console.log('User 1 email:', pm.environment.get('email'));",
                  "console.log('Copy the verification code from backend logs into verificationCode.');"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Aysel\",\n  \"lastName\": \"Mammadova\",\n  \"middleName\": \"\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"dateOfBirth\": \"2000-05-15\",\n  \"gender\": \"FEMALE\",\n  \"language\": \"ru\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "auth",
                "register"
              ]
            }
          }
        },
